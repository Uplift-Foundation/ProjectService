# Database Configuration
POSTGRES_PASSWORD=postgres
POSTGRES_DB=project_db
ConnectionString__DefaultConnection=Host=projectdb;Port=5432;Database=project_db;Username=postgres;Password=postgres

# Keycloak OAuth2 Configuration
Keycloak__Authority=https://devkeycloak.theabsoluteid.com/realms/forget_me_not
Keycloak__Audience=forget-me-not
Keycloak__OAuthClientId=forget-me-not
Keycloak__AuthClientSecret=***REDACTED_KEYCLOAK_SECRET***

# Microservice URLs (for aggregating habits and tasks)
HabitService__Url=http://host.docker.internal:82
TaskService__Url=http://host.docker.internal:83
